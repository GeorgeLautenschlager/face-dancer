{
  "$defs": {
    "ApplyDelta": {
      "description": "Authoritative change the character's code applies (session -> character).\n\nShares ``correlation_id`` with the ``propose_delta`` it finalizes.",
      "properties": {
        "type": {
          "const": "apply_delta",
          "default": "apply_delta",
          "title": "Type",
          "type": "string"
        },
        "schema_version": {
          "default": 1,
          "title": "Schema Version",
          "type": "integer"
        },
        "message_id": {
          "format": "uuid",
          "title": "Message Id",
          "type": "string"
        },
        "correlation_id": {
          "format": "uuid",
          "title": "Correlation Id",
          "type": "string"
        },
        "delta": {
          "$ref": "#/$defs/Delta"
        }
      },
      "required": [
        "correlation_id",
        "delta"
      ],
      "title": "ApplyDelta",
      "type": "object"
    },
    "Claim": {
      "description": "One surfaced rule, ~ a matched rider clause: prose plus an optional effect.\n\n``claim`` is the mandatory prose a dumb host reads; ``effect`` is the optional\nstructured enhancement a host can mechanize. A claim-only Claim is valid.",
      "properties": {
        "claim": {
          "title": "Claim",
          "type": "string"
        },
        "effect": {
          "anyOf": [
            {
              "$ref": "#/$defs/ClaimEffect"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "claim"
      ],
      "title": "Claim",
      "type": "object"
    },
    "ClaimEffect": {
      "description": "A structured suggestion a claim may carry \u2014 an op + payload, never a verdict.\n\nMirrors the rider's RiderEffect (op from the closed vocabulary, open payload,\nno tags). The session adjudicates it; the contest never asserts a final number.",
      "properties": {
        "op": {
          "$ref": "#/$defs/EffectOp"
        },
        "payload": {
          "additionalProperties": true,
          "title": "Payload",
          "type": "object"
        }
      },
      "required": [
        "op"
      ],
      "title": "ClaimEffect",
      "type": "object"
    },
    "Contest": {
      "description": "Character-surfaced claims, not verdicts (character -> session).",
      "properties": {
        "type": {
          "const": "contest",
          "default": "contest",
          "title": "Type",
          "type": "string"
        },
        "schema_version": {
          "default": 1,
          "title": "Schema Version",
          "type": "integer"
        },
        "message_id": {
          "format": "uuid",
          "title": "Message Id",
          "type": "string"
        },
        "correlation_id": {
          "format": "uuid",
          "title": "Correlation Id",
          "type": "string"
        },
        "claims": {
          "items": {
            "$ref": "#/$defs/Claim"
          },
          "title": "Claims",
          "type": "array"
        }
      },
      "required": [
        "correlation_id"
      ],
      "title": "Contest",
      "type": "object"
    },
    "Delta": {
      "description": "One effect: a single op, the tag-set it applies under, and its payload.",
      "properties": {
        "op": {
          "$ref": "#/$defs/EffectOp"
        },
        "tags": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Tags",
          "type": "array",
          "uniqueItems": true
        },
        "payload": {
          "additionalProperties": true,
          "title": "Payload",
          "type": "object"
        }
      },
      "required": [
        "op"
      ],
      "title": "Delta",
      "type": "object"
    },
    "EffectOp": {
      "description": "The closed, versioned set of effect operations a delta may carry.",
      "enum": [
        "reduce",
        "scale",
        "negate",
        "grant_save",
        "modify_roll",
        "replace"
      ],
      "title": "EffectOp",
      "type": "string"
    },
    "Intent": {
      "description": "Character-side opener; the session adjudicates it into a propose_delta.\n\n``action`` and ``target`` are the simple, host-understood contract the session\nreads and adjudicates; the character names a target but never asserts its\nlegality (affordance is session-owned). ``narration`` is optional in-character\nflair the session may render but never parses for mechanics.",
      "properties": {
        "type": {
          "const": "intent",
          "default": "intent",
          "title": "Type",
          "type": "string"
        },
        "schema_version": {
          "default": 1,
          "title": "Schema Version",
          "type": "integer"
        },
        "message_id": {
          "format": "uuid",
          "title": "Message Id",
          "type": "string"
        },
        "correlation_id": {
          "format": "uuid",
          "title": "Correlation Id",
          "type": "string"
        },
        "action": {
          "title": "Action",
          "type": "string"
        },
        "target": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Target"
        },
        "narration": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Narration"
        }
      },
      "required": [
        "correlation_id",
        "action"
      ],
      "title": "Intent",
      "type": "object"
    },
    "ProposeDelta": {
      "description": "Session-proposed change, not yet committed (session -> character).",
      "properties": {
        "type": {
          "const": "propose_delta",
          "default": "propose_delta",
          "title": "Type",
          "type": "string"
        },
        "schema_version": {
          "default": 1,
          "title": "Schema Version",
          "type": "integer"
        },
        "message_id": {
          "format": "uuid",
          "title": "Message Id",
          "type": "string"
        },
        "correlation_id": {
          "format": "uuid",
          "title": "Correlation Id",
          "type": "string"
        },
        "delta": {
          "$ref": "#/$defs/Delta"
        }
      },
      "required": [
        "correlation_id",
        "delta"
      ],
      "title": "ProposeDelta",
      "type": "object"
    },
    "RequestRoll": {
      "description": "A save or check to resolve (session -> character). DC is session-owned.",
      "properties": {
        "type": {
          "const": "request_roll",
          "default": "request_roll",
          "title": "Type",
          "type": "string"
        },
        "schema_version": {
          "default": 1,
          "title": "Schema Version",
          "type": "integer"
        },
        "message_id": {
          "format": "uuid",
          "title": "Message Id",
          "type": "string"
        },
        "correlation_id": {
          "format": "uuid",
          "title": "Correlation Id",
          "type": "string"
        },
        "kind": {
          "title": "Kind",
          "type": "string"
        },
        "dc": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dc"
        }
      },
      "required": [
        "correlation_id",
        "kind"
      ],
      "title": "RequestRoll",
      "type": "object"
    },
    "RollResult": {
      "description": "A rolled result; total == natural + modifier, computed in code elsewhere.",
      "properties": {
        "type": {
          "const": "roll_result",
          "default": "roll_result",
          "title": "Type",
          "type": "string"
        },
        "schema_version": {
          "default": 1,
          "title": "Schema Version",
          "type": "integer"
        },
        "message_id": {
          "format": "uuid",
          "title": "Message Id",
          "type": "string"
        },
        "correlation_id": {
          "format": "uuid",
          "title": "Correlation Id",
          "type": "string"
        },
        "natural": {
          "title": "Natural",
          "type": "integer"
        },
        "modifier": {
          "title": "Modifier",
          "type": "integer"
        },
        "total": {
          "title": "Total",
          "type": "integer"
        }
      },
      "required": [
        "correlation_id",
        "natural",
        "modifier",
        "total"
      ],
      "title": "RollResult",
      "type": "object"
    }
  },
  "discriminator": {
    "mapping": {
      "apply_delta": "#/$defs/ApplyDelta",
      "contest": "#/$defs/Contest",
      "intent": "#/$defs/Intent",
      "propose_delta": "#/$defs/ProposeDelta",
      "request_roll": "#/$defs/RequestRoll",
      "roll_result": "#/$defs/RollResult"
    },
    "propertyName": "type"
  },
  "oneOf": [
    {
      "$ref": "#/$defs/ProposeDelta"
    },
    {
      "$ref": "#/$defs/ApplyDelta"
    },
    {
      "$ref": "#/$defs/Contest"
    },
    {
      "$ref": "#/$defs/Intent"
    },
    {
      "$ref": "#/$defs/RequestRoll"
    },
    {
      "$ref": "#/$defs/RollResult"
    }
  ]
}
